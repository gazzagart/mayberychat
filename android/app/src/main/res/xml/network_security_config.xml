<?xml version="1.0" encoding="utf-8"?>
<!--
  Network security config for LetsYak.

  Cleartext (plain http://) is allowed ONLY to localhost and the Android
  emulator host alias (10.0.2.2) so developers can connect to the local
  backend without TLS. All other traffic is HTTPS-only.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
